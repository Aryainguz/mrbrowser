# Mr. Browser environment configuration
# Copy this file to .env and adjust values

# ── Core ──────────────────────────────────────────────────────
# Port the API server listens on
MRBROWSER_PORT=7331

# Run Chromium in headless mode (true/false)
MRBROWSER_HEADLESS=true

# Path to Chromium executable (leave empty for auto-detect)
MRBROWSER_CHROMIUM_PATH=

# Disable Chromium sandbox (required in Docker, use with caution on host)
MRBROWSER_NO_SANDBOX=false

# ── Storage ───────────────────────────────────────────────────
# SQLite database path
MRBROWSER_DB_PATH=./mrbrowser.db

# ── Logging ───────────────────────────────────────────────────
# Log level: debug, info, warn, error
MRBROWSER_LOG_LEVEL=info

# Disable ANSI colors in output
# NO_COLOR=1

# ── Browser ───────────────────────────────────────────────────
# Default browser window size
MRBROWSER_WINDOW_WIDTH=1920
MRBROWSER_WINDOW_HEIGHT=1080

# Default timeout for browser operations (seconds)
MRBROWSER_TIMEOUT=30

# ── Production (optional PostgreSQL) ──────────────────────────
# Uncomment and set to switch from SQLite to PostgreSQL
# MRBROWSER_DB_DRIVER=postgres
# MRBROWSER_DB_DSN=postgres://mrbrowser:changeme@localhost:5432/mrbrowser?sslmode=disable

# ── Docker PostgreSQL ─────────────────────────────────────────
POSTGRES_PASSWORD=changeme
